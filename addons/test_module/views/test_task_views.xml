<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_test_task_tree" model="ir.ui.view">
        <field name="name">test.task.tree</field>
        <field name="model">test.task</field>
        <field name="arch" type="xml">
            <list string="Tasks">
                <field name="name" />
                <field name="is_done" />
            </list>
        </field>
    </record>

    <record id="view_test_task_form" model="ir.ui.view">
        <field name="name">test.task.form</field>
        <field name="model">test.task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="description" />
                        <field name="is_done" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_test_task" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">test.task</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_test_task"
        name="Tasks"
        parent="menu_test_module_root"
        action="action_test_task"
        sequence="20"
    />
</odoo>
