<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="act_op_activity_analysis_pivot_view" model="ir.actions.act_window">
        <field name="name">Activity Analysis</field>
        <field name="res_model">op.activity</field>
        <field name="view_mode">pivot</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="target">current</field>
    </record>

    <record id="act_win_progress_activity_wizard_action" model="ir.actions.act_window">
        <field name="name">Add Activity</field>
        <field name="res_model">activity.progress.wizard</field>
        <field name="view_mode">form,list</field>
        <field name="context">{}</field>
        <field name="target">new</field>
        <field name="binding_model_id">Student progression</field>
    </record>

    <record id="action_migration_report" model="ir.actions.act_window">
        <field name="name">Migration Analysis</field>
        <field name="res_model">migration.report</field>
        <field name="view_mode">pivot</field>
        <field name="context">{}</field>
        <field name="target">current</field>
    </record>
</odoo>
