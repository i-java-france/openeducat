<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="achievement_type_multi_comp_rule" model="ir.rule">
        <field name="name">Activity Type multi-company</field>
        <field name="model_id" ref="Activity Type" />
        <field
            name="domain_force"
        >['|',('company_id','=',False),'&amp;',('company_id','in',company_ids),'|',('company_id','child_of',[user.company_id.id]),('company_id','in',user.company_ids.ids)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>

    <record id="activity_multi_comp_rule" model="ir.rule">
        <field name="name">Activity multi-company</field>
        <field name="model_id" ref="Student Activity" />
        <field
            name="domain_force"
        >['|',('company_id','=',False),'&amp;',('company_id','in',company_ids),'|',('company_id','child_of',[user.company_id.id]),('company_id','in',user.company_ids.ids)]</field>
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>
</odoo>
