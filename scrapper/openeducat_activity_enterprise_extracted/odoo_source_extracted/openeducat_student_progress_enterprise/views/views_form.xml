<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_progress_form" model="ir.ui.view">
        <field name="name">Student Progression Form</field>
        <field name="model">op.student.progression</field>
        <field name="type">form</field>
        <field name="priority">16</field>
        <field name="arch" type="xml">
<form>
    
                    
    <header>
        
                        
        <field name="state" widget="statusbar"/>
        
                        
        <button name="state_draft" type="object" string="Reset To Draft" class="oe_highlight" invisible="state in ('draft','done')"/>
        
                        
        <button name="state_open" type="object" string="In Progress" class="oe_highlight" invisible="state in ('cancel','open','done')"/>
        
                        
        <button name="state_rejected" type="object" string="Cancel" class="oe_highlight" invisible="state in ('cancel','draft','done')"/>
        
                        
        <button name="state_done" type="object" string="Done" class="oe_highlight" invisible="state in ('cancel','draft','done')"/>
        
                    
    </header>
    
                    
    <sheet>
        
                        
        <field name="active" invisible="1"/>
        
                        
        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
        
                        
        <group name="StudentData">
            
                            
            <group>
                
                                
                <field name="name" readonly="True" force_save="1"/>
                
                                
                <field name="date" readonly="state != 'draft'"/>
                
                            
            </group>
            
                            
            <group>
                
                                
                <field name="student_id" readonly="state != 'draft'"/>
                
                                
                <field name="created_by"/>
                
                                
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                
                            
            </group>
            
                        
        </group>
        
                        
        <notebook>
                        </notebook>
        
                    
    </sheet>
    
                
    <chatter/>
    
                
</form>
        </field>
    </record>
</odoo>
