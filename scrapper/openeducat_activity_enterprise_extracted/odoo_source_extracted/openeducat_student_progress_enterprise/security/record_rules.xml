<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="student_progression_multi_comp_rule" model="ir.rule">
        <field name="name">Student progression multi-company</field>
        <field name="model_id" ref="Student progression"/>
        <field name="domain_force">
                ['|',('company_id','=',False),'&amp;',('company_id','in',company_ids),'|',('company_id','child_of',[user.company_id.id]),('company_id','in',user.company_ids.ids)]
            </field>
        <field name="perm_read"   eval="True"/>
        <field name="perm_write"  eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
