<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_academic_plan" model="ir.actions.report">
        <field name="name">Academic Plan</field>
        <field name="model">op.academic.plan</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">openeducat_core_enterprise.report_op_academic_plan</field>
        <field name="print_report_name">'Academic Plan - %s' % (object.name)</field>
        <field name="binding_model_id">OpenEduCat Academic Plan</field>
    </record>

    <record id="action_report_student_course_enrollment" model="ir.actions.report">
        <field name="name">Course Enrollment</field>
        <field name="model">op.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">openeducat_core_enterprise.report_student_course_enrollment</field>
        <field name="print_report_name">'Course Enrollment - %s' % (object.name)</field>
        <field name="binding_model_id">Student</field>
    </record>

    <record id="action_report_student_information" model="ir.actions.report">
        <field name="name">Student Information</field>
        <field name="model">op.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">openeducat_core_enterprise.report_student_information</field>
        <field name="print_report_name">'Student Information - %s' % (object.name)</field>
        <field name="binding_model_id">Student</field>
    </record>
</odoo>
