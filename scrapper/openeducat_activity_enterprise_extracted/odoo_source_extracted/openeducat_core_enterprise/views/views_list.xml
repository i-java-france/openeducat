<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="op_student_badge_tree_view" model="ir.ui.view">
        <field name="name">Badge list</field>
        <field name="model">op.gamification.badge</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list>
    
                    
    <field name="name"/>
    
                    
    <field name="description"/>
    
                
</list>
        </field>
    </record>

    <record id="view_op_academic_plan_stages_tree" model="ir.ui.view">
        <field name="name">op.academic.plan.stages.list</field>
        <field name="model">op.academic.plan.stages</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list string="Marks Detail Line">
    
                    
    <field name="sequence" widget="handle"/>
    
                    
    <field name="name"/>
    
                    
    <field name="state"/>
    
                    
    <field name="company_id" groups="base.group_multi_company" optional="show"/>
    

                
</list>
        </field>
    </record>

    <record id="view_op_area_tree" model="ir.ui.view">
        <field name="name">op.area.list</field>
        <field name="model">op.area</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list string="Area">
    
                    
    <field name="name"/>
    
                    
    <field name="code"/>
    
                    
    <field name="company_id"/>
    
                
</list>
        </field>
    </record>

    <record id="view_op_assessment_type_tree" model="ir.ui.view">
        <field name="name">op.assessment.type.list</field>
        <field name="model">op.assessment.type</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list string="Marks Detail Line">
    
                    
    <field name="name"/>
    
                    
    <field name="code"/>
    
                    
    <field name="parent_id"/>
    
                    
    <field name="company_id" groups="base.group_multi_company" optional="show"/>
    

                
</list>
        </field>
    </record>

    <record id="view_op_board_affiliation_tree" model="ir.ui.view">
        <field name="name">op.board.affiliation.list</field>
        <field name="model">op.board.affiliation</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list>
    
                    
    <field name="name"/>
    
                    
    <field name="code"/>
    
                    
    <field name="company_id" groups="base.group_multi_company" optional="show"/>
    
                
</list>
        </field>
    </record>

    <record id="view_course_category_tree" model="ir.ui.view">
        <field name="name">op.course.category.list</field>
        <field name="model">op.course.category</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list>
    
                    
    <field name="name"/>
    
                    
    <field name="code"/>
    
                    
    <field name="desc"/>
    
                    
    <field name="icon" optional="hide"/>
    
                    
    <field name="parent_id" optional="hide"/>
    
                    
    <field name="active" widget="boolean_toggle" optional="hide"/>
    
                    
    <field name="company_id" groups="base.group_multi_company" optional="show"/>
    
                
</list>
        </field>
    </record>

    <record id="view_op_course_plan_tree" model="ir.ui.view">
        <field name="name">op.course.plan.list</field>
        <field name="model">op.course.plan</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list string="Course Plan">
    
                    
    <field name="name"/>
    
                    
    <field name="course_id"/>
    
                    
    <field name="academic_term_id"/>
    
                    
    <field name="academic_plan_id" optional="show"/>
    
                
</list>
        </field>
    </record>

    <record id="view_op_intake_year_tree" model="ir.ui.view">
        <field name="name">op.intake.year.list</field>
        <field name="model">op.intake.year</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list string="Intake Year">
    
                    
    <field name="name"/>
    
                    
    <field name="academic_year_id"/>
    
                    
    <field name="start_date"/>
    
                    
    <field name="end_date"/>
    
                    
    <field name="company_id"/>
    
                
</list>
        </field>
    </record>

    <record id="view_op_section_tree" model="ir.ui.view">
        <field name="name">op.section.list</field>
        <field name="model">op.section</field>
        <field name="type">list</field>
        <field name="priority">8</field>
        <field name="arch" type="xml">
<list>
    
                    
    <field name="name"/>
    
                    
    <field name="subject_id"/>
    
                    
    <field name="course_ids"/>
    
                    
    <field name="batch_ids"/>
    
                    
    <field name="student_course_ids" widget="many2many_tags"/>
    
                    
    <field name="company_id" groups="base.group_multi_company" optional="show"/>
    
                
</list>
        </field>
    </record>

    <record id="view_op_specialization_tree" model="ir.ui.view">
        <field name="name">op.specialization.list</field>
